generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// CORE USER MODEL
// -----------------------------------------------------------------------------
model User {
  id               String   @id @default(uuid())
  phone            String   @unique
  name             String
  email            String?
  passwordHash     String
  gender           String?
  region           String?
  balance          Float    @default(0)
  dataBalanceGB    Int      @default(0)
  points           Int      @default(0)
  profileCompleted Boolean  @default(false)
  giftPaused       Boolean  @default(false)
  status           String   @default("active") // active, blocked
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relationships
  personalization  UserPersonalization?
  billingHistory   BillingHistory[]
  supportTickets   SupportTicket[]
  rewards          Reward[]
}

// -----------------------------------------------------------------------------
// USER PERSONALIZATION (Optimized & flattened for Power BI Tabular mapping)
// -----------------------------------------------------------------------------
model UserPersonalization {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Demographics / Setup (Flattened to Booleans/Strings instead of nested JSON)
  partner             String   @default("No")
  dependents          Boolean  @default(false)
  phoneService        Boolean  @default(false)
  multipleLines       Boolean  @default(false)
  
  // Services
  internetService     String   // e.g., "Fiber", "VDSL"
  onlineSecurity      Boolean  @default(false)
  techSupport         Boolean  @default(false)
  paperlessBilling    Boolean  @default(false)
  onlineBackup        Boolean  @default(false)
  deviceProtection    Boolean  @default(false)
  streamingTV         Boolean  @default(false)
  streamingMovies     Boolean  @default(false)
  
  // Billing & Plans
  contractType        String   // e.g., "One year", "Month-to-month"
  paymentMethod       String   // e.g., "Vodafone Cash", "Credit Card"
  monthlyCharges      Float    @default(0.0)
  preferredPackage    String   // e.g., "Super Flex 100"
  avgConsumption      String   // e.g., "High", "Medium", "Low"
  
  // Notifications Preferences (Flattened Array)
  notifySms           Boolean  @default(false)
  notifyPush          Boolean  @default(false)
  notifyEmail         Boolean  @default(false)
  
  preferredOffers     String   // Comma separated string "Data, Gaming"
  switchReason        String?  // Optional text field
  privacyPolicyAgreed Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// SYSTEM CATALOGS (Offers, Tickets, Billing, Rewards)
// -----------------------------------------------------------------------------
model Offer {
  id           String   @id // e.g., "offer_1"
  name         String
  price        Float
  dataGB       Int
  minutes      Int
  validityDays Int
  type         String   // e.g., "bundle", "addon"
  description  String
  createdAt    DateTime @default(now())
}

model BillingHistory {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount        Float
  date          DateTime @default(now())
  status        String   // e.g., "Paid", "Pending", "Failed"
  description   String
  dataGB        Int      @default(0)   // Stores the GB capacity granted at purchase time
}

model SupportTicket {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  subject       String
  status        String   @default("Open") // "Open", "Closed", "In Progress"
  priority      String   @default("Low")  // "Low", "High", "Critical"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Reward {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  points        Int
  description   String
  dateEarned    DateTime @default(now())
}

// -----------------------------------------------------------------------------
// ADMIN & RBAC MODELS
// -----------------------------------------------------------------------------
model Admin {
  id               String   @id @default(uuid())
  username         String   @unique
  passwordHash     String
  role             String   @default("staff") // "owner" or "staff"
  
  // Granular Permissions Matrix
  canViewUsers     Boolean  @default(false)
  canEditUsers     Boolean  @default(false)
  canManageBilling Boolean  @default(false)
  canModerateUsers Boolean  @default(false)
  canDeleteUsers   Boolean  @default(false)
  canManageOffers  Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
